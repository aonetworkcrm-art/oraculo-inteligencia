# ══════════════════════════════════════════════════════════════
#  ORÁCULO DE INTELIGENCIA — Environment Configuration
#  Copy this file to .env and fill in your keys
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────
PORT=8080
DEBUG=false
SECRET_KEY=change-this-to-a-random-string

# ─── External Threat Intelligence APIs ─────────────────────
# (System works without these, but they enhance capabilities)

# Shodan — Search for exposed services
# https://account.shodan.io/
SHODAN_API_KEY=

# Hunter.io — Find email addresses by domain
# https://hunter.io/api-keys
HUNTER_API_KEY=

# HaveIBeenPwned — Check for data breaches (PAID API)
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# VirusTotal — Analyze domains/IPs for malware
# https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# Censys — Internet asset discovery
# https://search.censys.io/account/api
CENSYS_TOKEN=

# ─── Telegram Integration (Telethon) ───────────────────────
# Get credentials at: https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
# Session file name (created automatically after login)
TG_SESSION=oraculo_tg_session

# ─── Discord Integration (optional) ────────────────────────
# Discord bot token for scraping public channels
DISCORD_TOKEN=

# ─── Elasticsearch (optional) ──────────────────────────────
# Leave empty to use in-memory index
ES_HOSTS=http://localhost:9200
ES_API_KEY=
ES_USER=
ES_PASSWORD=

# ─── Proxy / Tor ───────────────────────────────────────────
# Tor SOCKS5 proxy for deep web access
# Install Tor: https://www.torproject.org/download/tor/
TOR_PROXY=socks5h://127.0.0.1:9050
# Use Tor for ALL requests (true/false)
USE_TOR=false
# Comma-separated list of proxy URLs
COMBO_PROXIES=

# ─── Data Generation ───────────────────────────────────────
# Use sample data when no real data is available
SAMPLE_DATA=true

# ─── OPSEC / Headers ───────────────────────────────────────
# Custom User-Agent for HTTP requests (leave empty for auto-rotation)
ORACLE_USER_AGENT=
# Proxy for Oracle Engine requests
ORACLE_PROXY=
